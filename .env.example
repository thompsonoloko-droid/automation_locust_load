# .env.example — copy this to .env and fill in your credentials
# NEVER commit .env to git

# ─── Target ──────────────────────────────────────────────────────────────────
TARGET_HOST=https://demoblaze.com
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10

# ─── Credentials (required for login-dependent tests) ────────────────────────
TEST_USERNAME=your-email@example.com
TEST_PASSWORD=YourPassword123!

# ─── Load parameters (optional overrides) ────────────────────────────────────
LOCUST_USERS=50
LOCUST_SPAWN_RATE=5
LOCUST_RUN_TIME=5m
LOCUST_MIN_WAIT=1
LOCUST_MAX_WAIT=3

# ─── SLA thresholds ──────────────────────────────────────────────────────────
SLA_MAX_RESPONSE_MS=2000
SLA_MAX_FAILURE_RATE=1.0
SLA_MIN_RPS=10.0
