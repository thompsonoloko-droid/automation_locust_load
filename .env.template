# Demoblaze Load Test Configuration
# ===================================
# This file stores sensitive test credentials.
# 
# IMPORTANT:
# - Copy this file to .env (without .template)
# - Add your actual credentials
# - .env is git-ignored and will NOT be committed
# - Use ONLY test accounts, never production credentials

# Test Account Credentials (Required)
# ===================================
# Register a test account at: https://demoblaze.com/index.html#signup
# 
# Example valid format:
#   TEST_USERNAME=mytest_01@example.com
#   TEST_PASSWORD=TestPassword123!
#
# The load tests will use these instead of hardcoded defaults

TEST_USERNAME=your_test_email@example.com
TEST_PASSWORD=your_test_password

# Optional: API Host Override
# ===========================
# Uncomment to use a different API host (e.g., staging, local)
# TARGET_API_HOST=https://api.staging.demoblaze.com
# TARGET_HOST=https://staging.demoblaze.com

# Optional: Load Test Configuration
# ===========================
# Number of virtual users to simulate
# LOCUST_USERS=20

# Ramp-up rate (users per second)
# LOCUST_SPAWN_RATE=2

# Test duration (e.g., 60s, 5m)
# LOCUST_RUNTIME=5m

# Enable headless mode (non-interactive)
# LOCUST_HEADLESS=true
